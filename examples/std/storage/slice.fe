import "../groups/numeric" as numeric

struct Slice<T> {
	let buf: &T
	let length: u32

	fn static new<U>(buf: &T, length: U) -> Self where numeric::Unsigned<U> {
		let new_slice: Self

		new_slice.buf = buf
		new_slice.length = length to u32

		new_slice
	}
}

import "../ops/address/subscript" as subscript
impl<T, U> subscript::#Indexable<RefType: Slice<T>, BaseType: T, IndexType: U> where numeric::Unsigned<U> {
    fn inline #OP_SUBSCRIPT(ref: RefType, index: IndexType) -> BaseType {
		ref.buf[index]
	}
}
