import "../../groups/numeric" as numeric

trait #Less_Than<LeftType, RightType, RetType> {
    fn inline #OP_LESS_THAN(left: LeftType, right: RightType) -> RetType
}

impl<T> #Less_Than<LeftType: T, RightType: T, RetType: bool> where numeric::Signed<T> {
    fn inline #OP_LESS_THAN(left: LeftType, right: RightType) -> RetType {
        #llvm_op("icmp slt", left, right)
    }
}

impl<T> #Less_Than<LeftType: T, RightType: T, RetType: bool> where numeric::Unsigned<T> {
    fn inline #OP_LESS_THAN(left: LeftType, right: RightType) -> RetType {
        #llvm_op("icmp ult", left, right)
    }
}
