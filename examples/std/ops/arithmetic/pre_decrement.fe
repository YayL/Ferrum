import "../../groups/numeric" as numeric
import "subtraction" as subtraction

trait #Pre_Decrement<ValueType, RetType> {
	fn inline #OP_PRE_DECREMENT(ref: ValueType) -> RetType
}

impl<T> #Pre_Decrement<ValueType: MutPlace<T>, RetType: T> where subtraction::#Subtraction<T, T, T> {
	fn inline #OP_PRE_DECREMENT(value: ValueType) -> RetType {
		value = value - 1 to T
	}
}

