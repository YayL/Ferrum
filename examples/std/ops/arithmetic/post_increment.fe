import "../../groups/numeric" as numeric
import "addition" as addition

trait #Post_Increment<ValueType, RetType> {
	fn inline #OP_POST_INCREMENT(ref: ValueType) -> RetType
}

impl<T> #Post_Increment<ValueType: MutPlace<T>, RetType: T> where addition::#Addition<T, T, T> {
	fn inline #OP_POST_INCREMENT(value: ValueType) -> RetType {
		let old = value
		value = value + 1 to T
		old
	}
}
