import "../../groups/numeric" as numeric
import "addition" as addition

trait Post_Increment {
	fn inline #OP_POST_INCREMENT(ref: &mut Self) -> mut Self
}

impl Post_Increment for (impl addition::Addition) {
	fn inline #OP_POST_INCREMENT(ref: &mut Self) -> mut Self {
		let old: mut Self = *ref
		*ref = *ref + 1
		old
	}
}
