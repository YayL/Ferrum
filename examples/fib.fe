import "std/lib" as std

fn main(argc: i32) -> i32 {
	fib(argc)
}

fn fib(n: i32) -> i32 {
	if n == 0 {
		return 0
	} else if n <= 2 {
		return 1
	}

	// start at fib(3)
	let mut i: i32 = 3
	let mut temp: i32 = 0
	let mut prev: i32 = 1
	let mut curr: i32 = 2

	for i < n, ++i {
		temp = curr
		curr = temp + prev
		prev = temp
	}

	return curr
}
